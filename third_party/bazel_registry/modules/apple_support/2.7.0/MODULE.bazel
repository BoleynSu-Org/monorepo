module(
    name = 'apple_support',
    bazel_compatibility = ['>=7.4.0'],
    version = '2.7.0',
)

bazel_dep(
    name = 'bazel_features',
    version = '1.50.0',
)

bazel_dep(
    name = 'bazel_skylib',
    version = '1.9.0',
)

bazel_dep(
    name = 'platforms',
    version = '1.1.0',
)

bazel_dep(
    name = 'rules_cc',
    version = '0.2.20',
)

apple_cc_configure_extension = use_extension(
    '//crosstool:setup.bzl',
    'apple_cc_configure_extension',
)

use_repo(
    apple_cc_configure_extension,
    'local_config_apple_cc',
    'local_config_apple_cc_toolchains',
)

register_toolchains(
    '@local_config_apple_cc_toolchains//:all',
)

xcode_configure_extension = use_extension(
    '//xcode:xcode_configure.bzl',
    'xcode_configure_extension',
)

use_repo(
    xcode_configure_extension,
    'local_config_xcode',
)

toolchain_env = use_repo_rule(
    '//toolchain:toolchain_env.bzl',
    'toolchain_env',
)

toolchain_env(
    name = 'apple_support_toolchain_env',
)

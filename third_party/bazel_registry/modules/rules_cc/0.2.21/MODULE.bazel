module(
    name = 'rules_cc',
    version = '0.2.21',
)

bazel_dep(
    name = 'bazel_features',
    version = '1.51.0',
)

bazel_dep(
    name = 'bazel_skylib',
    version = '1.9.0',
)

bazel_dep(
    name = 'platforms',
    version = '1.1.0',
)

bazel_dep(
    name = 'protobuf',
    version = '35.1',
    repo_name = 'com_google_protobuf',
)

cc_configure_extension = use_extension(
    '//cc:extensions.bzl',
    'cc_configure_extension',
)

use_repo(
    cc_configure_extension,
    'local_config_cc',
    'local_config_cc_toolchains',
)

register_toolchains(
    '@local_config_cc_toolchains//:all',
    '//cc/private/toolchain/test:default_test_runner_toolchain',
)

bazel_dep(
    name = 'rules_python',
    version = '2.2.0',
)

compatibility_proxy = use_extension(
    '//cc:extensions.bzl',
    'compatibility_proxy',
)

use_repo(
    compatibility_proxy,
    'cc_compatibility_proxy',
)

local_bazel_import = use_repo_rule(
    '//:local_bazel.bzl',
    'local_bazel_import',
)

local_bazel_import(
    name = 'local_bazel',
)

module(
    name = 'rules_oci',
    version = '2.3.0',
)

bazel_dep(
    name = 'aspect_bazel_lib',
    version = '2.22.5',
)

bazel_dep(
    name = 'bazel_features',
    version = '1.44.0',
)

bazel_dep(
    name = 'bazel_skylib',
    version = '1.9.0',
)

bazel_dep(
    name = 'package_metadata',
    version = '0.0.7',
)

bazel_dep(
    name = 'platforms',
    version = '1.0.0',
)

bazel_dep(
    name = 'tar.bzl',
    version = '0.10.1',
)

oci = use_extension(
    '//oci:extensions.bzl',
    'oci',
)

oci.toolchains(
)

use_repo(
    oci,
    'oci_crane_toolchains',
    'oci_regctl_toolchains',
)

register_toolchains(
    '@oci_crane_toolchains//:all',
    '@oci_regctl_toolchains//:all',
)

toolchains = use_extension(
    '@aspect_bazel_lib//lib:extensions.bzl',
    'toolchains',
)

toolchains.zstd(
)

use_repo(
    toolchains,
    'zstd_toolchains',
)

register_toolchains(
    '@zstd_toolchains//:all',
)

toolchains_1 = use_extension(
    '@aspect_bazel_lib//lib:extensions.bzl',
    'toolchains',
)

toolchains_1.jq(
)

use_repo(
    toolchains_1,
    'jq_toolchains',
)

toolchains_2 = use_extension(
    '@tar.bzl//tar:extensions.bzl',
    'toolchains',
)

use_repo(
    toolchains_2,
    'bsd_tar_toolchains',
)

register_toolchains(
    '@bsd_tar_toolchains//:all',
)

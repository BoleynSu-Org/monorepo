module(
    name = 'toolchains_llvm',
    bazel_compatibility = ['>=7.0.0'],
    version = '1.8.0',
)

bazel_dep(
    name = 'bazel_features',
    version = '1.51.0',
)

bazel_dep(
    name = 'bazel_skylib',
    version = '1.9.0',
)

bazel_dep(
    name = 'aspect_bazel_lib',
    version = '2.22.5',
)

bazel_dep(
    name = 'rules_cc',
    version = '0.2.22',
)

bazel_dep(
    name = 'platforms',
    version = '1.1.0',
)

bazel_dep(
    name = 'helly25_bzl',
    version = '0.5.0',
)

llvm_distributions = use_extension(
    '//toolchain/extensions:distributions.bzl',
    'llvm_distributions',
)

use_repo(
    llvm_distributions,
    'llvm_distributions_data',
)

bazel_dep(
    name = 'tar.bzl',
    version = '0.10.6',
)

toolchains = use_extension(
    '@tar.bzl//tar:extensions.bzl',
    'toolchains',
)

use_repo(
    toolchains,
    'bsd_tar_toolchains_darwin_amd64',
    'bsd_tar_toolchains_darwin_arm64',
    'bsd_tar_toolchains_linux_amd64',
    'bsd_tar_toolchains_linux_arm64',
    'bsd_tar_toolchains_windows_amd64',
    'bsd_tar_toolchains_windows_arm64',
)
